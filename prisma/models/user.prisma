model User {
    id            String    @id @default(cuid())
    name          String?
    email         String    @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]

    role UserRole @default(DEFAULT)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    bookings            Booking[]
    accompaniedBookings Booking[] @relation("BookingAccompaniedMembers")
}

enum UserRole {
    DEFAULT
    ADMIN
    DEVELOPER
}
