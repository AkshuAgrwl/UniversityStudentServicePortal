model People {
    id               String          @id
    name             String
    email            String          @unique
    mobile_no        String          @unique
    designation      DesignationType
    positions        Position[]      @relation("PositionPerson")
    venuesAsStaff    Venue[]         @relation("VenueStaffIncharge")
    venuesAsIncharge Venue[]         @relation("VenueFacultyIncharge")
}

model Position {
    id    String @id
    role  String
    email String @unique

    person_in_position People @relation("PositionPerson", fields: [personInPositionId], references: [id])
    personInPositionId String
}

model Venue {
    id                  String    @id
    name                String
    type                VenueType
    availableForBooking Boolean   @default(true)

    staffInchargeId String?
    staffIncharge   People? @relation(name: "VenueStaffIncharge", fields: [staffInchargeId], references: [id])

    facultyInchargeId String?
    facultyIncharge   People? @relation(name: "VenueFacultyIncharge", fields: [facultyInchargeId], references: [id])
}

enum VenueType {
    LECTURE_HALL
    SEMINAR_HALL
    LAB
}

enum DesignationType {
    PROFESSOR
    DISTINGUISHED_PROFESSOR
    ASSOCIATE_PROFESSOR
    ASSISTANT_PROFESSOR
    TECHNICAL_SUPERINTENDENT
    JR_TECHNICAL_SUPERINTENDENT
    JR_TECHNICIAN
    JR_ASSISTANT
}
